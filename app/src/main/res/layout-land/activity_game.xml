<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_landscape_background">

    <!-- La GameView occupe tout l'espace en arrière-plan -->
    <fr.iut_fbleau.chuzzle.view.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp" />

    <!-- Calque UI : Trois colonnes pour un centrage parfait des boîtes latérales -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Colonne GAUCHE : Décollée du bord pour se rapprocher de la grille -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="50dp">

            <LinearLayout
                android:id="@+id/hudLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center"
                android:background="@drawable/hud_background"
                android:elevation="10dp"
                android:minWidth="150dp">

                <TextView
                    android:id="@+id/scoreTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_score_initial"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="1.5"
                    android:layout_marginBottom="25dp"/>

                <TextView
                    android:id="@+id/movesTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_moves_initial"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="1.5" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Colonne MILIEU : Espace réservé à la grille (poids plus important) -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.6" />

        <!-- Colonne DROITE : Décollée du bord pour se rapprocher de la grille -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="50dp">

            <LinearLayout
                android:id="@+id/gameOverLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/game_over_background"
                android:elevation="30dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone"
                android:minWidth="150dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/game_over_title_short"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="2" />

                <!-- Masqué en paysage -->
                <TextView
                    android:id="@+id/gameOverStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/gameOverSeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <!-- Invisible mais gardé pour compatibilité ID -->
    <TextView
        android:id="@+id/gameOverTextView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</RelativeLayout>
