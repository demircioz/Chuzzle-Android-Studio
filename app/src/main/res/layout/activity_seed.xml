<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_portrait_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/seed_prompt"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="2"
            android:elevation="10dp"
            android:layout_marginBottom="25dp"/>

        <EditText
            android:id="@+id/seedEditText"
            android:layout_width="260dp"
            android:layout_height="60dp"
            android:inputType="numberSigned"
            android:hint="@string/seed_hint"
            android:textSize="18sp"
            android:padding="12dp"
            android:gravity="center"
            android:background="@drawable/edit_text_seed_style"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:elevation="5dp"
            android:layout_marginBottom="35dp"/>

        <Button
            android:id="@+id/playSeedButton"
            android:layout_width="240dp"
            android:layout_height="65dp"
            android:background="@drawable/button_play_style"
            app:backgroundTint="@null"
            android:elevation="10dp"
            android:text="@string/seed_play_button"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>

</RelativeLayout>